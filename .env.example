# LLM
LLM_PROVIDER=ollama
LLM_MODEL=qwen2.5:7b
OLLAMA_BASE_URL=http://localhost:11434

# PostgreSQL (optional - system works without it)
POSTGRES_DSN=postgresql+asyncpg://marketatlas:marketatlas@localhost:5432/marketatlas

# Neo4j (optional - system works without it)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=test

# Qdrant (optional - system works without it)
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=marketatlas_events

# API
API_HOST=0.0.0.0
API_PORT=8000
